{
  "name": "agent-pay",
  "version": "0.1.0",
  "description": "Payment infrastructure for AI agents. A2A payments with one API call. No crypto. No complexity.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "agents", "payments", "langchain", "crewai", "autogen", "langgraph", "a2a", "multi-agent", "agent-payments", "llm", "openai", "anthropic", "agent-pay"],
  "author": "AgentPay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gs-lang/AgentPay.git",
    "directory": "sdk"
  },
  "homepage": "https://agent-pay.pro",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5",
    "tsup": "^8"
  },
  "files": ["dist", "README.md"]
}
