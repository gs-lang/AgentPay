# Stripe — set these in your Replit Secrets (or .env.local)
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Optional: override the publishable key for Next.js client
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...

# Webhook signing secret (get from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: base URL for Stripe Checkout redirect
NEXT_PUBLIC_BASE_URL=https://your-repl-url.replit.app
